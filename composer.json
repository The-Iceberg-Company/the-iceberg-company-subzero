{
  "name": "the-iceberg-company/subzero",
  "description": "PHP client for the Subzero tokenization vault",
  "type": "library",
  "version": "1.0.2",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Iceberg\\Subzero\\": "src/"
    },
    "classmap": [
      "src/Models",
      "src/Exceptions"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Iceberg\\Subzero\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php vendor/bin/phpunit"
  }
}
